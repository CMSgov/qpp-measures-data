{
  "name": "qpp-measures-data",
  "version": "11.0.0-beta.1",
  "description": "Quality Payment Program Measures Data Repository",
  "repository": {
    "type": "git",
    "url": "https://github.com/CMSgov/qpp-measures-data.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24",
    "npm": ">=11.11"
  },
  "scripts": {
    "build": "tsc && npm run build:types",
    "test": "npm run jest:cov",
    "posttest": "cp coverage/lcov.info lcov.info",
    "init:measures": "scripts/measures/initialize-measures",
    "update:measures": "scripts/measures/update-measures",
    "build:types": "ts-node scripts/types/bundle-types.ts",
    "build:benchmarks": "scripts/benchmarks/build-benchmarks",
    "create:clinical-clusters": "TS_NODE_FILES=true ts-node scripts/clinical-clusters/create-clinical-cluster-csv-from-pdf.ts",
    "build:clinical-clusters": "bash scripts/clinical-clusters/build-clinical-clusters",
    "verify:clinical-clusters": "bash scripts/clinical-clusters/verify-clinical-clusters",
    "clinical-clusters": "bash scripts/clinical-clusters/run-clinical-clusters",
    "build:mvp": "scripts/mvp/build-mvp",
    "parse:mvp": "scripts/mvp/parse-mvp-data",
    "export:measures": "bash scripts/measures/export-measures",
    "manage:allowed-programs": "scripts/measures/manage-programs",
    "export:data-dictionary": "ts-node scripts/data-dictionary/generate-data-dictionary.ts",
    "pretest": "npm run lint",
    "lint": "eslint scripts index.spec.ts",
    "lint:fix": "eslint scripts index.spec.ts --fix",
    "pre-commit": "tools/pre-commit.sh",
    "jest:cov": "TS_NODE_FILES=true NODE_OPTIONS='--max-old-space-size=3072' jest --coverage --coverage-provider=v8"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/json-merge-patch": "^1.0.0",
    "@types/natural-compare-lite": "^1.4.2",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "adm-zip": "^0.6.0",
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "bluebird": "^3.7.2",
    "commander": "^15.0.0",
    "csv-parse": "^7.0.1",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.7.0",
    "fast-json-patch": "^3.1.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "json-2-csv": "^5.5.11",
    "json-merge-patch": "^1.0.2",
    "memfs": "^4.64.0",
    "natural-compare-lite": "^1.4.0",
    "officeparser": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pre-commit": "^2.0.0",
    "rimraf": "^6.1.3",
    "toad-uri-js": "^5.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/papaparse": "^5.5.2",
    "app-root-path": "^3.1.0",
    "fs-extra": "^11.3.6",
    "lodash": "^4.18.1",
    "papaparse": "^5.5.4",
    "yaml": "^2.9.0"
  },
  "pre-commit": [
    "pre-commit"
  ],
  "eslintIgnore": [
    "/dist/**/*.js"
  ]
}
